for(i in seq_len(nrow(stations))){
  station_name <- stations$Station[i]
  message("Processing ", station_name, "...")
 
  data <- read_wind_data(stations$Path[i], station_name)
  wind_speed <- data$WindSpeed
  if(!is.null(cached_parameters) && station_name %in% cached_parameters$Station){
    parameter_row <- cached_parameters[cached_parameters$Station == station_name, ][1, ]
    fit <- make_fit_from_parameters(wind_speed, parameter_row)
  } else {
    fit <- fit_sigmoid_model(wind_speed)
  }
  fits[[station_name]] <- fit
 
  p <- fit$parameters
  parameter_table <- data.frame(
    Station = station_name,
    Weight_1 = p[1],
    Weight_2 = 1 - p[1],
    Shape_1 = p[2],
    Scale_1 = p[3],
    Shape_2 = p[4],
    Scale_2 = p[5],
    Sigmoid_Alpha = fit$alpha,
    Sigmoid_Center = fit$center,
    Negative_Log_Likelihood = fit$nll,
    Convergence_Code = fit$convergence
  )
 
  gof <- compute_gof(wind_speed, fit)
  gof$Station <- station_name
  gof <- gof[, c("Station", setdiff(names(gof), "Station"))]
 
  x_grid <- seq(min(wind_speed), max(wind_speed), length.out = 300)
 
  pdf_data <- data.frame(
    Station = station_name,
    WindSpeed = x_grid,
    FittedPDF = model_pdf(x_grid, fit)
  )
 
  cdf_data <- data.frame(
    Station = station_name,
    WindSpeed = x_grid,
    FittedCDF = model_cdf(x_grid, fit)
  )
 
  empirical_cdf <- data.frame(
    Station = station_name,
    WindSpeed = sort(wind_speed),
    EmpiricalCDF = ecdf(wind_speed)(sort(wind_speed))
  )
 
  mc <- data.frame()
  for(simulation in 1:1000){
    simulated <- simulate_sigmoid_model(length(wind_speed), fit)
    mc <- rbind(
      mc,
      data.frame(
        Station = station_name,
        Simulation = simulation,
        Simulated_Mean = mean(simulated),
        Simulated_SD = sd(simulated),
        Observed_Mean = mean(wind_speed),
        Observed_SD = sd(wind_speed)
      )
    )
  }
 
  data$WPD <- compute_wpd(data$WindSpeed)
 
  annual_energy <- aggregate(
    WindSpeed ~ Station + Year,
    data = data,
    FUN = mean
  )
  names(annual_energy) <- c("Station", "Year", "Mean_WindSpeed")
  annual_energy$AEP_MWh <- compute_aep(annual_energy$Mean_WindSpeed)
 
  annual_wpd <- aggregate(
    WPD ~ Station + Year,
    data = data,
    FUN = mean
  )
  names(annual_wpd) <- c("Station", "Year", "Mean_WPD")
 
  all_cleaned[[station_name]] <- data
  all_parameters[[station_name]] <- parameter_table
  all_gof[[station_name]] <- gof
  all_pdf[[station_name]] <- pdf_data
  all_cdf[[station_name]] <- cdf_data
  all_empirical_cdf[[station_name]] <- empirical_cdf
  all_monte_carlo[[station_name]] <- mc
  all_energy[[station_name]] <- annual_energy
  all_wpd[[station_name]] <- annual_wpd
}
 
