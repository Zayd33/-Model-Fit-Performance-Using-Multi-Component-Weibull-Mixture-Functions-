sigmoid_function <- function(x, alpha, center){
  1 / (1 + exp(-alpha * (x - center)))
}
 
component_normalizers <- function(shape1, scale1, shape2, scale2, alpha, center, upper_limit){
  z1 <- integrate(
    function(z){
      sigmoid_function(z, alpha, center) *
        dweibull(z, shape = shape1, scale = scale1)
    },
    lower = 0,
    upper = upper_limit,
    subdivisions = 1000,
    rel.tol = 0.000001
  )$value
 
  z2 <- integrate(
    function(z){
      (1 - sigmoid_function(z, alpha, center)) *
        dweibull(z, shape = shape2, scale = scale2)
    },
    lower = 0,
    upper = upper_limit,
    subdivisions = 1000,
    rel.tol = 0.000001
  )$value
 
  c(z1 = max(z1, 0.000000000001), z2 = max(z2, 0.000000000001))
}
 
sigmoid_bimodal_weibull_pdf <- function(
    x, weight1, shape1, scale1, shape2, scale2, alpha, center, upper_limit){
 
  normalizers <- component_normalizers(
    shape1, scale1, shape2, scale2, alpha, center, upper_limit
  )
 
  s <- sigmoid_function(x, alpha, center)
  component1 <- s * dweibull(x, shape = shape1, scale = scale1) / normalizers["z1"]
  component2 <- (1 - s) * dweibull(x, shape = shape2, scale = scale2) / normalizers["z2"]
 
  pmax(weight1 * component1 + (1 - weight1) * component2, 0.000000000001)
}
 
sigmoid_bimodal_weibull_cdf <- function(
    x, weight1, shape1, scale1, shape2, scale2, alpha, center, upper_limit){
 
  normalizers <- component_normalizers(
    shape1, scale1, shape2, scale2, alpha, center, upper_limit
  )
 
  one_value <- function(q){
    if(q <= 0){
      return(0)
    }
 
    upper_q <- min(q, upper_limit)
 
    c1 <- integrate(
      function(z){
        sigmoid_function(z, alpha, center) *
          dweibull(z, shape = shape1, scale = scale1) / normalizers["z1"]
      },
      lower = 0,
      upper = upper_q,
      subdivisions = 1000,
      rel.tol = 0.000001
    )$value
 
    c2 <- integrate(
      function(z){
        (1 - sigmoid_function(z, alpha, center)) *
          dweibull(z, shape = shape2, scale = scale2) / normalizers["z2"]
      },
      lower = 0,
      upper = upper_q,
      subdivisions = 1000,
      rel.tol = 0.000001
    )$value
 
    min(max(weight1 * c1 + (1 - weight1) * c2, 0), 1)
  }
 
  vapply(x, one_value, numeric(1))
}
 
trapezoid_integral <- function(x, y){
  sum((y[-1] + y[-length(y)]) / 2 * diff(x))
}
 
sigmoid_bimodal_weibull_pdf_fast <- function(
    x, weight1, shape1, scale1, shape2, scale2, alpha, center, norm_grid){
 
  s_grid <- sigmoid_function(norm_grid, alpha, center)
  g1_grid <- s_grid * dweibull(norm_grid, shape = shape1, scale = scale1)
  g2_grid <- (1 - s_grid) * dweibull(norm_grid, shape = shape2, scale = scale2)
 
  z1 <- max(trapezoid_integral(norm_grid, g1_grid), 0.000000000001)
  z2 <- max(trapezoid_integral(norm_grid, g2_grid), 0.000000000001)
 
  s <- sigmoid_function(x, alpha, center)
  component1 <- s * dweibull(x, shape = shape1, scale = scale1) / z1
  component2 <- (1 - s) * dweibull(x, shape = shape2, scale = scale2) / z2
 
  pmax(weight1 * component1 + (1 - weight1) * component2, 0.000000000001)
}
 
negative_log_likelihood <- function(parameters, x, alpha, center, norm_grid){
  density <- sigmoid_bimodal_weibull_pdf_fast(
    x = x,
    weight1 = parameters[1],
    shape1 = parameters[2],
    scale1 = parameters[3],
    shape2 = parameters[4],
    scale2 = parameters[5],
    alpha = alpha,
    center = center,
    norm_grid = norm_grid
  )
  -sum(log(density))
}
 
fit_sigmoid_model <- function(x){
  center <- mean(x)
  alpha <- 1 / sd(x)
  upper_limit <- max(x) * 5
  norm_grid <- seq(0, upper_limit, length.out = 2000)
 
  start <- c(
    weight1 = 0.50,
    shape1 = 2.00,
    scale1 = max(mean(x) * 0.75, 0.10),
    shape2 = 3.00,
    scale2 = max(mean(x) * 1.25, 0.10)
  )
 
  fit <- optim(
    par = start,
    fn = negative_log_likelihood,
    x = x,
    alpha = alpha,
    center = center,
    norm_grid = norm_grid,
    method = "L-BFGS-B",
    lower = c(0.001, 0.10, 0.10, 0.10, 0.10),
    upper = c(0.999, 20.00, 50.00, 20.00, 50.00),
    control = list(maxit = 1000)
  )
 
  grid_x <- seq(0, upper_limit, length.out = 5000)
  grid_pdf <- sigmoid_bimodal_weibull_pdf_fast(
    x = grid_x,
    weight1 = fit$par[1],
    shape1 = fit$par[2],
    scale1 = fit$par[3],
    shape2 = fit$par[4],
    scale2 = fit$par[5],
    alpha = alpha,
    center = center,
    norm_grid = norm_grid
  )
 
  dx <- diff(grid_x)
  grid_cdf <- c(0, cumsum((grid_pdf[-1] + grid_pdf[-length(grid_pdf)]) / 2 * dx))
  grid_cdf <- grid_cdf / max(grid_cdf)
  grid_probability <- grid_pdf / sum(grid_pdf)
 
  list(
    parameters = fit$par,
    alpha = alpha,
    center = center,
    upper_limit = upper_limit,
    norm_grid = norm_grid,
    grid_x = grid_x,
    grid_pdf = grid_pdf,
    grid_cdf = grid_cdf,
    grid_probability = grid_probability,
    nll = fit$value,
    convergence = fit$convergence
  )
}
 
make_fit_from_parameters <- function(x, parameter_row){
  upper_limit <- max(x) * 5
  norm_grid <- seq(0, upper_limit, length.out = 2000)
  parameters <- c(
    weight1 = parameter_row$Weight_1,
    shape1 = parameter_row$Shape_1,
    scale1 = parameter_row$Scale_1,
    shape2 = parameter_row$Shape_2,
    scale2 = parameter_row$Scale_2
  )
 
  grid_x <- seq(0, upper_limit, length.out = 5000)
  grid_pdf <- sigmoid_bimodal_weibull_pdf_fast(
    x = grid_x,
    weight1 = parameters[1],
    shape1 = parameters[2],
    scale1 = parameters[3],
    shape2 = parameters[4],
    scale2 = parameters[5],
    alpha = parameter_row$Sigmoid_Alpha,
    center = parameter_row$Sigmoid_Center,
    norm_grid = norm_grid
  )
 
  dx <- diff(grid_x)
  grid_cdf <- c(0, cumsum((grid_pdf[-1] + grid_pdf[-length(grid_pdf)]) / 2 * dx))
  grid_cdf <- grid_cdf / max(grid_cdf)
  grid_probability <- grid_pdf / sum(grid_pdf)
 
  list(
    parameters = parameters,
    alpha = parameter_row$Sigmoid_Alpha,
    center = parameter_row$Sigmoid_Center,
    upper_limit = upper_limit,
    norm_grid = norm_grid,
    grid_x = grid_x,
    grid_pdf = grid_pdf,
    grid_cdf = grid_cdf,
    grid_probability = grid_probability,
    nll = negative_log_likelihood(
      parameters,
      x = x,
      alpha = parameter_row$Sigmoid_Alpha,
      center = parameter_row$Sigmoid_Center,
      norm_grid = norm_grid
    ),
    convergence = parameter_row$Convergence_Code
  )
}
 
model_pdf <- function(x, fit){
  p <- fit$parameters
  sigmoid_bimodal_weibull_pdf_fast(
    x, p[1], p[2], p[3], p[4], p[5],
    fit$alpha, fit$center, fit$norm_grid
  )
}
 
model_cdf <- function(x, fit){
  approx(
    x = fit$grid_x,
    y = fit$grid_cdf,
    xout = x,
    rule = 2,
    ties = "ordered"
  )$y
}
 
compute_gof <- function(x, fit){
  x_sorted <- sort(x)
  empirical <- ecdf(x)(x_sorted)
  theoretical <- model_cdf(x_sorted, fit)
  residuals <- empirical - theoretical
 
  n <- length(x)
  n_params <- 5
  log_likelihood <- -fit$nll
 
  breaks <- unique(as.numeric(quantile(
    x, probs = seq(0, 1, length.out = 9), type = 7, na.rm = TRUE
  )))
  observed <- as.numeric(table(cut(x, breaks = breaks, include.lowest = TRUE)))
  cdf_upper <- model_cdf(breaks[-1], fit)
  cdf_lower <- model_cdf(breaks[-length(breaks)], fit)
  expected <- n * pmax(cdf_upper - cdf_lower, 0.000000000001)
  chi_square <- sum((observed - expected)^2 / expected)
  chi_df <- length(observed) - n_params - 1
  chi_p <- if(chi_df > 0) pchisq(chi_square, chi_df, lower.tail = FALSE) else NA
 
  data.frame(
    AIC = -2 * log_likelihood + 2 * n_params,
    BIC = -2 * log_likelihood + log(n) * n_params,
    RMSE = sqrt(mean(residuals^2)),
    Chi_Square = chi_square,
    Chi_Square_DF = chi_df,
    Chi_Square_PValue = chi_p,
    Kolmogorov_Smirnov = max(abs(residuals))
  )
}
 
simulate_sigmoid_model <- function(n, fit){
  sample(fit$grid_x, size = n, replace = TRUE, prob = fit$grid_probability)
}
 
compute_wpd <- function(wind_speed, air_density = 1.225){
  0.5 * air_density * wind_speed^3
}
 
compute_aep <- function(
    mean_wind_speed,
    air_density = 1.225,
    rotor_radius = 40,
    power_coefficient = 0.40,
    availability = 0.95,
    hours_per_year = 8760){
 
  swept_area <- pi * rotor_radius^2
  power_watts <- 0.5 * air_density * swept_area * power_coefficient *
    mean_wind_speed^3
  power_watts * availability * hours_per_year / 1000000
}
 
round_numeric_columns <- function(data, digits = 5){
  numeric_cols <- vapply(data, is.numeric, logical(1))
  data[numeric_cols] <- lapply(data[numeric_cols], round, digits = digits)
  data
}
 
