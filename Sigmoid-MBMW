clean_names <- function(x){
  tolower(gsub("[^A-Za-z0-9]+", "", x))
}
 
month_to_number <- function(month_value){
  month_text <- trimws(as.character(month_value))
  month_number <- suppressWarnings(as.integer(month_text))
  needs_conversion <- is.na(month_number)
  month_number[needs_conversion] <- match(
    tolower(substr(month_text[needs_conversion], 1, 3)),
    tolower(month.abb)
  )
  month_number
}
 
read_wind_data <- function(file_path, station_name){
  raw_data <- read.csv(file_path, stringsAsFactors = FALSE, check.names = FALSE)
  names(raw_data) <- clean_names(names(raw_data))
 
  wind_column <- intersect(
    c("windspeed", "winspeed", "windspd", "speed"),
    names(raw_data)
  )
  wind_column <- wind_column[1]
 
  if(!all(c("year", "month") %in% names(raw_data))){
    stop("Year or Month column is missing in ", station_name)
  }
 
  if(is.na(wind_column)){
    stop("Wind speed column is missing in ", station_name)
  }
 
  data <- data.frame(
    Station = station_name,
    Year = as.integer(raw_data$year),
    Month = month_to_number(raw_data$month),
    WindSpeed = suppressWarnings(as.numeric(raw_data[[wind_column]]))
  )
 
  data <- data[complete.cases(data), ]
  data <- data[data$WindSpeed >= 0, ]
  data
}
 
